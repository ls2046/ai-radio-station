# AI Radio Station
# Copy this file to .env and fill in only the providers you plan to use.

# API server
HOST=0.0.0.0
PORT=4000

# Frontend -> API base URL
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Shared LLM timeouts (milliseconds)
AI_LLM_TIMEOUT_MS=12000
HOST_LLM_TIMEOUT_MS=12000
HOST_USER_SPEAK_LLM_TIMEOUT_MS=12000

# LLM provider for chat and conversation analysis
# Supported: deepseek / openai / minimax
AI_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_BASE_URL=https://api.openai.com

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_CHAT_BASE_URL=https://api.minimaxi.com
MINIMAX_CHAT_MODEL=MiniMax-M2.7
MINIMAX_HOST_MODEL=

# TTS provider for the radio host
# Supported: minimax / bytedance / volcengine / edge / mock
AI_TTS_PROVIDER=mock
MINIMAX_TTS_BASE_URL=https://api.minimaxi.com
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_LANGUAGE=Chinese
MINIMAX_TTS_FORMAT=mp3
MINIMAX_VOICE_ID=Chinese (Mandarin)_Radio_Host
MINIMAX_VOICE_SPEED=1
MINIMAX_VOICE_PITCH=0
MINIMAX_VOICE_VOLUME=1

# ByteDance / OpenSpeech TTS
BYTEDANCE_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
BYTEDANCE_TTS_API_KEY=
BYTEDANCE_TTS_APP_ID=
BYTEDANCE_TTS_ACCESS_KEY=
BYTEDANCE_TTS_RESOURCE_ID=seed-tts-2.0
BYTEDANCE_TTS_SPEAKER=zh_female_cancan_mars_bigtts
BYTEDANCE_TTS_MODEL=
BYTEDANCE_TTS_FORMAT=mp3
BYTEDANCE_TTS_SAMPLE_RATE=24000
BYTEDANCE_TTS_ENABLE_TIMESTAMP=true
BYTEDANCE_TTS_LANGUAGE=zh
BYTEDANCE_TTS_SPEECH_RATE=0
BYTEDANCE_TTS_LOUDNESS_RATE=0
BYTEDANCE_TTS_EMOTION=
BYTEDANCE_TTS_EMOTION_SCALE=

# Suno direct mode
# To use real Suno generation, create your own local
# data/manual-generate-request.json from the example file in data/.
SUNO_ENABLE_REAL=false
SUNO_MODEL=chirp-fenix
SUNO_AUTHORIZATION=
SUNO_BROWSER_TOKEN=
SUNO_DEVICE_ID=
SUNO_BROWSER_USER_AGENT=
SUNO_REQUEST_TOKEN=
SUNO_SESSION_TOKEN=
SUNO_TOKEN_PROVIDER=

# Optional compatibility cookie header for direct requests.
SUNO_API_KEY=
SUNO_COOKIE=
